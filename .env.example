# ─── Red Motos Chile · variables de entorno ───────────────────────────
# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas .env.local al repositorio.

# Gate del panel /admin (obligatoria)
ADMIN_PASSWORD=

# Recomendador IA real + captions del generador de posts (opcional, hay fallback local)
ANTHROPIC_API_KEY=

# Estudio de fotos + generador de posts con IA de imagen (kie.ai)
KIE_API_KEY=

# ─── Autofin "Araña 2.0" — simulador de cuotas (server-side, NUNCA NEXT_PUBLIC) ──
# Tokens y códigos los entrega Autofin. Los de QA están en el "Manual de
# Implementación de Araña 2.0" (v1.12). En PROD, los que entregue Autofin.
# IMPORTANTE: guardar el token YA percent-encoded (cada char no alfanumérico →
# %XX, p. ej. con encodeURIComponent). El código lo usa tal cual. Motivos: el
# server exige el token totalmente codificado (la forma "Postman" del manual da
# HTTP 400) y el token crudo trae ${...}/$/# que el dotenv de Next corrompe.
AUTOFIN_BASE_URL=https://fabdigital-qa.autofin.cl/autofin/api
AUTOFIN_SPIDER_URL=https://spiderqa.autofin.cl
AUTOFIN_COD_SPIDER=
AUTOFIN_TOKEN_CONFIG=
AUTOFIN_TOKEN_CUOTA=
AUTOFIN_TOKEN_INYECCION=
AUTOFIN_WEBHOOK_SECRET=
